# Copy this to .env.setup and fill in your values — never commit .env.setup
# All 3 values come from your Supabase project dashboard.

# Project Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Project Settings → API → service_role key (secret — keep this private)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# supabase.com/dashboard/account/tokens → "Generate new token"
SUPABASE_PAT=sbp_...
