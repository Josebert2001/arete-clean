# ============================================================
#  Arete — Environment Variables
#  Copy this file to .env.local for local development.
#  In production, set these in Vercel → Settings → Environment Variables.
# ============================================================

# Groq API key (AI Tutor + Code Explainer)
# Get yours free at https://console.groq.com  — no credit card required
GROQ_API_KEY=your_groq_api_key_here

# JDoodle Compiler API (Code Playground — "Try It" in each module)
# Sign up free at https://www.jdoodle.com/subscribe-api  (20 runs/day free)
JDOODLE_CLIENT_ID=your_jdoodle_client_id_here
JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret_here

# Restricts which site's browser may call the /api/* endpoints (CORS).
# Set to your deployed domain to stop other websites embedding your key.
# Leave unset to allow any origin ('*'). NOTE: CORS only blocks browsers —
# for real abuse protection add a rate limiter (e.g. Vercel KV / Upstash).
ALLOWED_ORIGIN=https://your-domain.vercel.app
