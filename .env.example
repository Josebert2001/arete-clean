# ============================================================
#  Arete — Environment Variables
#  Copy this file to .env.local for local development.
#  In production, set these in Vercel → Settings → Environment Variables.
# ============================================================

# Groq API key (AI Tutor + Code Explainer)
# Get yours free at https://console.groq.com  — no credit card required
GROQ_API_KEY=your_groq_api_key_here

# JDoodle Compiler API (Code Playground — "Try It" in each module)
# Sign up free at https://www.jdoodle.com/subscribe-api  (20 runs/day free)
JDOODLE_CLIENT_ID=your_jdoodle_client_id_here
JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret_here

# Supabase (auth + cloud progress sync + AI Tutor personalization)
# Used by both the frontend and the /api/* functions. Values come from
# Supabase → Project Settings → API (or run: node setup-supabase.mjs)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Sentry error monitoring (optional — leave unset to disable; the app no-ops).
# Create a free project at https://sentry.io → Settings → Client Keys (DSN).
# VITE_SENTRY_DSN is exposed to the browser (frontend errors); SENTRY_DSN is
# server-side (the /api/* functions). They can be the same project DSN.
VITE_SENTRY_DSN=
SENTRY_DSN=

# Restricts which site's browser may call the /api/* endpoints (CORS).
# Set to your deployed domain to stop other websites embedding your key.
# Leave unset to allow any origin ('*'). NOTE: CORS only blocks browsers —
# for real abuse protection add a rate limiter (e.g. Vercel KV / Upstash).
# Production canonical domain (apex redirects to www on Vercel):
ALLOWED_ORIGIN=https://www.aretecyb.tech
